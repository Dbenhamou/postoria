{
  "crons": [
    {
      "path": "/api/cron-publish",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron-emails",
      "schedule": "0 9 * * *"
    }
  ],
  "functions": {
    "pages/api/generate-visual.ts": {
      "maxDuration": 60
    }
  },
  "buildCommand": "NODE_OPTIONS=\"--max-old-space-size=3008\" npm run build"
}